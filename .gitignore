# ===== Datasets — raw images (too large / third-party license) =====
# CropAndWeed original images — download from official source instead
datasets/baseline_dataset_AB/**/images/
datasets/baseline_dataset_AB/**/masks/

# c_cropped — json annotations kept, images and masks excluded
datasets/c_cropped/**/*.jpg
datasets/c_cropped/**/*.png

# corn_augmented — augmented copies only, originals kept
datasets/corn_augmented/train/images/*_flip.*
datasets/corn_augmented/train/images/*_persp.*
datasets/corn_augmented/train/images/*_rot*.*
datasets/corn_augmented/train/labels/*_flip.*
datasets/corn_augmented/train/labels/*_persp.*
datasets/corn_augmented/train/labels/*_rot*.*

# ===== Model checkpoints =====
*.pth
*.pt
*.ckpt
checkpoints/
outputs/

# ===== Python =====
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# ===== Logs & temp files =====
*.log
runs/
wandb/
